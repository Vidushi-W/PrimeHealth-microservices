# Docker Compose Environment Variables
# Copy this file to .env and fill in your MongoDB URIs

MONGO_URI_DOCTOR=mongodb+srv://<user>:<password>@cluster.mongodb.net/doctor-db?retryWrites=true&w=majority
MONGO_URI_PATIENT=mongodb+srv://<user>:<password>@cluster.mongodb.net/patient-db?retryWrites=true&w=majority
MONGO_URI_APPOINTMENT=mongodb+srv://<user>:<password>@cluster.mongodb.net/appointment-db?retryWrites=true&w=majority
MONGO_URI_PAYMENT=mongodb+srv://<user>:<password>@cluster.mongodb.net/payment-db?retryWrites=true&w=majority
MONGO_URI_PRESCRIPTION=mongodb+srv://<user>:<password>@cluster.mongodb.net/prescription-db?retryWrites=true&w=majority

INTERNAL_SERVICE_TOKEN=<set-a-shared-random-token>
CROSS_SERVICE_SYNC_STRICT=false

# ─── Payments: default SIMULATED (no PayHere). See docs/PAYHERE_SANDBOX.md for PayHere. ───
PAYMENT_PROVIDER=SIMULATED
PAYMENT_SIMULATE_ALWAYS_SUCCESS=true

# PayHere (only when PAYMENT_PROVIDER=PAYHERE)
# PAYMENT_PROVIDER=PAYHERE
PAYHERE_USE_SANDBOX=true
PAYHERE_MERCHANT_ID=
PAYHERE_MERCHANT_SECRET=
PAYHERE_FRONTEND_BASE_URL=http://localhost:5173
PAYHERE_NOTIFY_URL=http://localhost:5004/api/payments/payhere/notify
