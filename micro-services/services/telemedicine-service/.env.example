PORT=5006
MONGO_URI=mongodb://localhost:27017/primehealth_telemedicine
JWT_SECRET=replace-with-strong-secret
JWT_EXPIRES_IN=7d
CORS_ORIGIN=*
APPOINTMENT_SERVICE_URL=http://localhost:5003
INTERNAL_SERVICE_TOKEN=

VIDEO_PROVIDER=jitsi
JITSI_BASE_URL=https://meet.jit.si
JAAS_APP_ID=
JAAS_KID=
JAAS_PRIVATE_KEY=
# Optional explicit script URL, e.g. https://8x8.vc/<JAAS_APP_ID>/external_api.js
JAAS_EXTERNAL_API_URL=
# Join window policy
TELEMEDICINE_JOIN_OPEN_BEFORE_START_MINUTES=10
TELEMEDICINE_JOIN_GRACE_AFTER_END_MINUTES=30
# Doctor starts meeting first; patient waits until doctor joins.
TELEMEDICINE_DOCTOR_HOST_REQUIRED=true

TWILIO_ACCOUNT_SID=
TWILIO_API_KEY=
TWILIO_API_SECRET=
TWILIO_ROOM_TTL_SECONDS=3600

AGORA_APP_ID=
AGORA_APP_CERTIFICATE=
AGORA_TOKEN_TTL_SECONDS=3600

CHAT_PRE_MINUTES=30
CHAT_POST_MINUTES=120
