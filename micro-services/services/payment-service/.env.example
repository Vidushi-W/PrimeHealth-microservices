PORT=5004
NODE_ENV=development
MONGO_URI=mongodb://localhost:27017/primehealth_payment
LOG_LEVEL=debug
CORS_ORIGIN=*
APPOINTMENT_SERVICE_URL=http://localhost:5003

# ─── Payment provider ────────────────────────────────────────────
# SIMULATED = local test (initiate + /confirm).
# STRIPE = hosted checkout on Stripe.
PAYMENT_PROVIDER=SIMULATED
# When SIMULATED: if false, confirm step randomly fails ~10% of the time.
PAYMENT_SIMULATE_ALWAYS_SUCCESS=true

# ─── Stripe (required when PAYMENT_PROVIDER=STRIPE) ─────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_FRONTEND_BASE_URL=http://localhost:5173
