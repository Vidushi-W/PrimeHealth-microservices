PORT=5004
NODE_ENV=development
MONGO_URI=mongodb://localhost:27017/primehealth_payment
LOG_LEVEL=debug
CORS_ORIGIN=*
APPOINTMENT_SERVICE_URL=http://localhost:5003

# ─── Payment provider ────────────────────────────────────────────
# SIMULATED = local test (initiate + /confirm, no PayHere). Default for early development.
# PAYHERE = hosted checkout (needs MERCHANT_ID + SECRET below).
PAYMENT_PROVIDER=SIMULATED
# When SIMULATED: if false, confirm step randomly fails ~10% of the time.
PAYMENT_SIMULATE_ALWAYS_SUCCESS=true

# ─── PayHere SANDBOX (optional) ─────────────────────────────────
# Sign up at https://sandbox.payhere.lk/ when using PAYMENT_PROVIDER=PAYHERE.
PAYHERE_USE_SANDBOX=true
PAYHERE_MERCHANT_ID=
# Paste exactly as shown in the sandbox portal (used as-is for MD5). If hash is still rejected, try:
# PAYHERE_MERCHANT_SECRET_DECODE_BASE64=true
PAYHERE_MERCHANT_SECRET=

# Vite dev server origin (return/cancel URLs)
PAYHERE_FRONTEND_BASE_URL=http://localhost:5173

# IPN callback — use a public URL (e.g. ngrok) if PayHere cannot reach localhost
PAYHERE_NOTIFY_URL=http://localhost:5004/api/payments/payhere/notify
