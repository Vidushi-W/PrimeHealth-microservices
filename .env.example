NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Auth
JWT_SECRET=change-me
JWT_EXPIRES_IN=7d
INTERNAL_SERVICE_TOKEN=primehealth-internal-sync-token

# MongoDB Atlas
ADMIN_MONGO_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/PrimeHealth-admin?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/PrimeHealth-admin?retryWrites=true&w=majority
MONGO_URI_DOCTOR=mongodb+srv://USER:PASS@cluster.mongodb.net/PrimeHealth-doctor?retryWrites=true&w=majority
MONGO_URI_PATIENT=mongodb+srv://USER:PASS@cluster.mongodb.net/PrimeHealth-patient?retryWrites=true&w=majority
MONGO_URI_APPOINTMENT=mongodb+srv://USER:PASS@cluster.mongodb.net/PrimeHealth-appointment?retryWrites=true&w=majority
MONGO_URI_PAYMENT=mongodb+srv://USER:PASS@cluster.mongodb.net/PrimeHealth-payment?retryWrites=true&w=majority
MONGO_URI_PRESCRIPTION=mongodb+srv://USER:PASS@cluster.mongodb.net/PrimeHealth-prescription?retryWrites=true&w=majority
TELEMEDICINE_MONGO_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/PrimeHealth-telemedicine?retryWrites=true&w=majority

# Service URLs for local host access
ADMIN_SERVICE_URL=http://localhost:5001
DOCTOR_SERVICE_URL=http://localhost:5002
APPOINTMENT_SERVICE_URL=http://localhost:5003
PAYMENT_SERVICE_URL=http://localhost:5004
PRESCRIPTION_SERVICE_URL=http://localhost:5005
TELEMEDICINE_SERVICE_URL=http://localhost:5006
PATIENT_SERVICE_URL=http://localhost:5007
NOTIFICATION_SERVICE_URL=http://localhost:5008

# Admin bootstrap
ADMIN_SEED_EMAIL=admin@primehealth.local
ADMIN_SEED_PASSWORD=change-me
CROSS_SERVICE_SYNC_STRICT=false
ADMIN_DIRECTORY_RECONCILE_MS=15000

# Payment provider
PAYMENT_PROVIDER=SIMULATED
PAYMENT_SIMULATE_ALWAYS_SUCCESS=true
PAYMENT_SIMULATE_RANDOM_FAILURE=false
PAYHERE_USE_SANDBOX=true
PAYHERE_MERCHANT_ID=
PAYHERE_MERCHANT_SECRET=
PAYHERE_FRONTEND_BASE_URL=http://localhost:5173
PAYHERE_NOTIFY_URL=http://localhost:5004/api/payments/payhere/notify
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_FRONTEND_BASE_URL=http://localhost:5173

# Telemedicine / realtime
VIDEO_PROVIDER=jitsi
JITSI_BASE_URL=https://meet.jit.si
TELEMEDICINE_JOIN_GRACE_AFTER_END_MINUTES=1440
CHAT_PRE_MINUTES=60
CHAT_POST_MINUTES=120
TWILIO_ACCOUNT_SID=
TWILIO_API_KEY=
TWILIO_API_SECRET=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_ROOM_TTL_SECONDS=3600
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=
AGORA_TOKEN_TTL_SECONDS=3600

# Patient AI / email integrations
OPENAI_API_KEY=
OPENAI_ANALYZER_MODEL=gpt-5
HF_TOKEN=
HF_TEXT_ANALYZER_MODEL=openai/gpt-oss-120b:fastest
HF_VISION_ANALYZER_MODEL=zai-org/GLM-4.5V:fastest
BREVO_API_KEY=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=PrimeHealth
REMINDER_EMAIL_CHECK_INTERVAL_MS=60000

# Notification integrations
EMAIL_ENABLED=false
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASS=
EMAIL_FROM_ADDRESS=
SMS_ENABLED=false
